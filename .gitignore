# Arquivos que NAO devem ir para o Git:
# dependencias baixadas, builds gerados, cache, logs, configuracoes locais
# e arquivos do sistema operacional.
#
# Arquivos importantes que devem continuar sendo enviados:
# src/, public/, backend/db.json, angular.json, package.json e package-lock.json.

# Dependencias do Node
/node_modules/

# Builds e arquivos compilados do Angular
/dist/
/tmp/
/out-tsc/
/bazel-out/
/.angular/cache/

# Cobertura de testes e resultados temporarios
/coverage/
/typings/
__screenshots__/
test-results/
playwright-report/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
libpeerconnection.log
testem.log

# Variaveis de ambiente e configuracoes sensiveis
.env
.env.*
!.env.example
!.env.exemplo

# Cache de estilos
.sass-cache/

# Arquivos de lock temporarios
/connect.lock

# Editores e IDEs
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/

# Visual Studio Code: guarda apenas configuracoes compartilhaveis
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

# Arquivos do sistema operacional
.DS_Store
Thumbs.db
desktop.ini